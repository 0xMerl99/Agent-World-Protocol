# Agent World Protocol — Environment Configuration

# Server ports
WS_PORT=8080
API_PORT=3000

# Simulation
TICK_RATE=1000

# World config
PERCEPTION_RADIUS=10
ZONE_SIZE=32

# Solana
SOLANA_RPC=https://api.mainnet-beta.solana.com
# For production, use Helius or Quicknode:
# SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Safety — set to false for live trading
DRY_RUN=true

# Protocol fee wallet (receives trading fees)
FEE_WALLET=

# PostgreSQL — world persists across restarts when set
# DATABASE_URL=postgresql://user:password@localhost:5432/agentworld
# For Railway/Render, this is auto-set when you add a Postgres addon
DATABASE_URL=

# Auto-save interval (ms) — how often world state is saved to DB
DB_SAVE_INTERVAL=30000

# Wallet authentication — set to true for production
# When false (default), any wallet string is accepted without signature verification
# When true, agents must sign a challenge with their Solana private key
REQUIRE_WALLET_AUTH=false
